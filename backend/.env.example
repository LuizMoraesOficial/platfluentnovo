# =============================================
# Be Fluent School — Variaveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores

# ----- APP -----
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
TZ=America/Sao_Paulo

# ----- DATABASE (Neon PostgreSQL) -----
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ----- SESSION -----
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=sua_chave_secreta_de_pelo_menos_64_caracteres_aqui_gere_uma_nova_e_unica

# ----- CORS -----
# Coloque o dominio do seu site (sem barra no final)
CORS_ALLOWED_ORIGINS=https://seudominio.com.br

# ----- EMAIL (opcional) -----
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply@seudominio.com.br
# SMTP_PASSWORD=sua_senha_de_email
# SMTP_FROM=noreply@seudominio.com.br

# ----- LOGGING -----
LOG_LEVEL=info
